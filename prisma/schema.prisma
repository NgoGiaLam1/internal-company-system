generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TblEmployee {
  id              String            @id @default(uuid())
  fullName        String
  email           String            @unique
  password        String
  phone           String? 
  avatarUrl       String?
  position        String
  roleId          String
  status          Status            @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  departmentId    String?
  department      TblDepartment?    @relation(fields: [departmentId], references: [id])
  role            TblRole           @relation(fields: [roleId], references: [id])
  leaveRequests   TblLeaveRequest[] @relation("EmployeeLeaveRequests")
  leadingProjects TblProject[]      @relation("ProjectLeader")
  tasks           TblTask[]         @relation("TaskAssignee")
  projects        TblProject[]      @relation("ProjectMembers")
  comments        TblTaskComment[]

  sentNotifications    TblNotification[]          @relation("NotificationSender")
  notifications        TblNotificationRecipient[]
  pushSubscriptions TblPushSubscription[]
}

model TblNotification {
  id      String           @id @default(uuid())
  title   String
  content String?
  type    NotificationType @default(GENERAL)

  senderId String?
  sender   TblEmployee? @relation("NotificationSender", fields: [senderId], references: [id])

  createdAt DateTime @default(now())

  recipients TblNotificationRecipient[]

  @@index([senderId])
  @@index([createdAt])
}

model TblNotificationRecipient {
  id String @id @default(uuid())

  notificationId String
  employeeId     String

  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  notification TblNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  employee     TblEmployee     @relation(fields: [employeeId], references: [id])

  @@unique([notificationId, employeeId])
  @@index([employeeId])
  @@index([employeeId, isRead])
  @@index([notificationId])
}

model TblPushSubscription {
  id String @id @default(uuid())

  employeeId String

  endpoint String @unique @db.Text

  p256dh String @db.Text

  auth String @db.Text

  createdAt DateTime @default(now())

  employee TblEmployee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model TblDepartment {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employees   TblEmployee[]
}

model TblProject {
  id          String        @id @default(uuid())
  name        String
  description String?
  leaderId    String?
  startDate   DateTime?
  endDate     DateTime?
  status      ProjectStatus @default(PLANNING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  leader      TblEmployee?  @relation("ProjectLeader", fields: [leaderId], references: [id])
  tasks       TblTask[]
  members     TblEmployee[] @relation("ProjectMembers")
}

model TblTask {
  id             String           @id @default(uuid())
  title          String
  description    String?
  status         TaskStatus       @default(TODO)
  priority       Priority         @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  projectId      String
  assigneeId     String?
  resultNote     String?
  resultFileName String?
  resultUrl      String?
  submittedAt    DateTime?
  assignee       TblEmployee?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project        TblProject       @relation(fields: [projectId], references: [id])
  comments       TblTaskComment[]
}

model TblTaskComment {
  id String @id @default(uuid())

  taskId     String
  employeeId String

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task TblTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  employee TblEmployee @relation(fields: [employeeId], references: [id])

  @@index([taskId])
}

model TblLeaveRequest {
  id         String      @id @default(uuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  employee   TblEmployee @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id])
}

model TblModule {
  id          String   @id @default(uuid())
  name        String   @unique
  href        String   @unique
  icon        String
  position    Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions TblPermission[]
}

model TblRole {
  id              String              @id @default(uuid())
  name            String              @unique
  description     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  employees       TblEmployee[]
  rolePermissions TblRolePermission[]
}

model TblPermission {
  id              String              @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime            @default(now())
  rolePermissions TblRolePermission[]
  moduleId        String
  module          TblModule           @relation(fields: [moduleId], references: [id])

  @@unique([moduleId, name])
}

model TblRolePermission {
  id           String        @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime      @default(now())
  permission   TblPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         TblRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

enum Status {
  ACTIVE
  INACTIVE
  RESIGNED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  SYSTEM
  GENERAL
  TASK
  PROJECT
  LEAVE
  COMMENT
}
